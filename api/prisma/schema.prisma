// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COMMERCE_ADMIN
  MEMBER
}

enum Category {
  FEATURE
  BUG
  IMPROVEMENT
  OTHER
}


model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  name                String
  role                Role                 @default(MEMBER)
  avatarUrl           String?
  bio                 String?
  phone               String?
  location            String?
  website             String?
  twitterHandle       String?
  githubHandle        String?
  linkedinHandle      String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
reviews             CommerceReview[]
  passwordResetTokens PasswordResetToken[]
  ownedCommerces      Commerce[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Commerce {
  id                 String                      @id @default(uuid())
  name               String
  slug               String                      @unique
  description        String?
  logoUrl            String?
  ownerId            String
  verified           Boolean                     @default(false)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  owner              User                        @relation(fields: [ownerId], references: [id])
  reviews            CommerceReview[]
  verificationTokens CommerceVerificationToken[]

  @@index([slug])
  @@index([ownerId])
  @@map("commerces")
}

model CommerceReview {
  id         String    @id @default(uuid())
  stars      Int
  category   Category?
  comment    String?
  authorId   String
  commerceId String
  author     User      @relation(fields: [authorId], references: [id])
  commerce   Commerce  @relation(fields: [commerceId], references: [id])
  createdAt  DateTime  @default(now())

  @@unique([authorId, commerceId])
  @@index([commerceId])
  @@map("commerce_reviews")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model CommerceVerificationToken {
  id         String   @id @default(uuid())
  token      String   @unique
  commerceId String
  commerce   Commerce @relation(fields: [commerceId], references: [id])
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@map("commerce_verification_tokens")
}
