# Base de datos
DB_USER=feedbackuser
DB_PASSWORD=feedbackpass
DB_NAME=feedbackboard
DB_PORT=3002
DATABASE_URL=postgresql://feedbackuser:feedbackpass@postgres:3002/feedbackboard
# Docker (NestJS dentro del container)
DATABASE_URL_DOCKER=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public

# Redis
